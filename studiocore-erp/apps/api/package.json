{
  "name": "@studiocore/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node --max-old-space-size=8192 ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "node --max-old-space-size=8192 ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "lint": "node --max-old-space-size=8192 ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/integration.test.cjs",
    "db:migrate": "npm run build && node dist/database/run-migrations.js",
    "db:seed": "npm run build && node dist/database/seed.js",
    "db:import:legacy:people": "npm run build && node dist/database/import-legacy-people.js",
    "db:migrate:legacy:documents": "npm run build && node dist/database/migrate-legacy-person-documents.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@supabase/supabase-js": "^2.100.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.3",
    "@types/node": "^22.15.3",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "pg-mem": "^3.0.5",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
