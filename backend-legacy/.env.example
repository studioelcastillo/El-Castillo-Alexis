APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_CLIENT=http://localhost:3000/
APP_SERVER=http://localhost:8000/
APP_TIMEZONE=UTC
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8000/
API_URL_LOGO = 

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gk_threshold
DB_USERNAME=postgres
DB_PASSWORD=rootroot

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

FCM_KEY=

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_SERVER}api/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL="${APP_SERVER}api/auth/facebook/callback"

# Internal Microservices Authentication
INTERNAL_API_TOKEN=your_secure_internal_token_here
INTERNAL_API_ALLOWED_SERVICES=ms-wscrap,ms-sso,desktop-app,ops-cli

# Restricted CORS allowlist for backend legacy
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://pruebas.livstre.com,https://terminado.livstre.com

# Microservices URLs
MS_WSCRAP_URL=http://localhost:3002

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL="${APP_SERVER}api/auth/github/callback"

MP_KEY=
MP_ACCESS_TOKEN=

TWILIO_SID=
TWILIO_AUTH_TOKEN=

OS_PHP_PATH = C:/AppServ/php83-nts/php.exe
OS_WSCRAP_DIR = C:/AppServ/www/el-castillo-webapp/wscrap/

# LiveJasmin Participation (Gold Line)
# true = usa ParticipationBonusService para calcular % de liquidacion en LiveJasmin
# false = LiveJasmin se liquida igual que las demas plataformas (usando models_goals)
LIVEJASMIN_PARTICIPATION_ENABLED=false

# Placeholder used by legacy seeders to avoid real third-party passwords in code
LEGACY_PLATFORM_PASSWORD_PLACEHOLDER=REDACTED_CHANGE_IN_PANEL
