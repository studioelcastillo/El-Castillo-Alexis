# Archivo versionado saneado para staging.
# Los valores privados reales deben vivir en `.secure/root.staging.env.local`
# o en variables del proveedor antes de materializar/desplegar.

[ENVIRONMENT]
ENVIRONMENT = staging
PORT = 3033

[SERVER]
API_URL = https://pruebas.livstre.com/api
VITE_API_URL = https://pruebas.livstre.com/api

[OPTIONS]
EMAIL_MULTIACCOUNT = false
CHANGE_USERS_PASSWORD = false

[SOCKET]
NOTIFICATION_BUTTON = false
SOCKET_KEY = GECKODE_THRESHOLD
SOCKET_HOST = pruebas.livstre.com
SOCKET_PORT = 6001

[FIREBASE]
FCM_APIKEY =
FCM_AUTHDOMAIN =
FCM_PROJECTID =
FCM_STORAGEBUCKET =
FCM_MESSAGINGSENDERID =
FCM_APPID =
FCM_MEASUREMENTID =

[MERCADOPAGO]
MP_KEY =

[SUPABASE]
VITE_SUPABASE_URL = https://pnnrsqocukixusmzrlhy.supabase.co
VITE_SUPABASE_ANON_KEY = TU_SUPABASE_ANON_KEY_STAGING
SUPABASE_SERVICE_ROLE_KEY = SOLO_EN_.SECURE_ROOT_STAGING_ENV_LOCAL
SUPABASE_PUBLISHABLE_KEY = TU_SUPABASE_PUBLISHABLE_KEY_STAGING
SUPABASE_SECRET_KEY = SOLO_EN_.SECURE_ROOT_STAGING_ENV_LOCAL

[OPENAI]
