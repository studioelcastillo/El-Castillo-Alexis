# Plantilla versionada saneada.
# Los valores privados reales deben vivir en `.secure/root.env.local`
# o en `.secure/root.<entorno>.env.local`.

[ENVIRONMENT]
ENVIRONMENT = local
PORT = 3033

[SERVER]
API_URL = https://pruebas.livstre.com/api
VITE_API_URL = https://pruebas.livstre.com/api
VITE_SCRAPING_API_URL = https://pruebas.livstre.com/erp-api/api/v1

[SUPABASE]
SUPABASE_URL = https://pnnrsqocukixusmzrlhy.supabase.co
VITE_SUPABASE_URL = https://pnnrsqocukixusmzrlhy.supabase.co
SUPABASE_ANON_KEY = TU_SUPABASE_ANON_KEY
VITE_SUPABASE_ANON_KEY = TU_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY = OPCIONAL_SOLO_EN_.SECURE_PARA_LOGIN_LOCAL
SUPABASE_SECRET_KEY = OPCIONAL_SOLO_EN_.SECURE_PARA_SCRIPTS_ADMIN
SUPABASE_PUBLISHABLE_KEY = OPCIONAL_PARA_DESPLIEGUES_REMOTOS

[OPTIONS]
EMAIL_MULTIACCOUNT = false
CHANGE_USERS_PASSWORD = false

[SOCKET]
NOTIFICATION_BUTTON = false
SOCKET_KEY = GECKODE_THRESHOLD
SOCKET_HOST = pruebas.livstre.com
SOCKET_PORT = 6001

[FIREBASE]
FCM_APIKEY = 
FCM_AUTHDOMAIN = 
FCM_PROJECTID = 
FCM_STORAGEBUCKET = 
FCM_MESSAGINGSENDERID = 
FCM_APPID = 
FCM_MEASUREMENTID = 

[MERCADOPAGO]
MP_KEY = 

[FRONTEND]
DASHBOARD_APP_URL = /
