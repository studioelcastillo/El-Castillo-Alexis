{
  "name": "el-castillo-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/dashboard/vite.config.ts apps/dashboard",
    "build": "node scripts/build-dashboard.mjs",
    "postbuild": "node scripts/copy-dashboard.mjs",
    "secrets:check": "node scripts/check-secrets.mjs",
    "secure:migrate": "node scripts/migrate-existing-envs.mjs",
    "secure:materialize": "node scripts/materialize-secure-env.mjs",
    "deploy:staging": "node scripts/deploy.mjs staging",
    "deploy:production": "node scripts/deploy.mjs production",
    "preview": "vite preview --config apps/dashboard/vite.config.ts apps/dashboard",
    "start": "node server.mjs",
    "lint": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --project apps/dashboard/tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.7.9",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.559.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.44",
    "pg": "^8.20.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
